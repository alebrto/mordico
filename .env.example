# Copia este archivo como .env y completa con tus credenciales de Supabase.
# Las encuentras en: Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anonima-publica

# Opcional: URL de tu Edge Function para el Asistente IA (ver README.md)
VITE_ASISTENTE_IA_ENDPOINT=https://tu-proyecto.functions.supabase.co/asistente-ia
